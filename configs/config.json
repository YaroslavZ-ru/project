{
  "db_path": "data/knowledge_base.db",
  "fasttext_model_path": "models/cc.ru.300.bin",
  "fallback_embeddings_path": "",
  "synonyms_path": "data/synonyms.json",
  "domain_templates_path": "configs/domain_templates.json",
  "domain_keywords_path": "configs/domain_keywords.json",
  "min_confidence": 0.3,
  "max_candidates": 20,
  "max_parameters": 15,
  "use_generative": false,
  "generative_model": "sberbank-ai/rugpt3small_based_on_gpt2",
  "generative_max_new_tokens": 100,
  "generative_temperature": 0.7,
  "generative_max_new_params": 3,
  "generative_timeout_seconds": 15.0,
  "min_parameters_for_generative": 5,
  "generative_keywords": [
    "материал",
    "размер",
    "тип",
    "скорость",
    "масса",
    "форма",
    "цвет",
    "температура",
    "давление",
    "напряжение",
    "длина",
    "ширина",
    "высота",
    "плотность",
    "мощность"
  ],
  "timeout_seconds": 5.0,
  "cache_embeddings": true,
  "log_level": "INFO",
  "cache_lemma_size": 1000,
  "max_synonyms_per_token": 2,
  "use_synonyms": true,
  "max_term_length": 100,
  "max_hint_length": 50,
  "word_vector_cache_size": 20000,
  "query_cache_size": 100,
  "use_faiss": false,
  "faiss_threshold": 10000,
  "fallback_domain_keywords_path": "configs/domain_keywords.json",
  "faiss_index_path": "",
  "session_ttl_seconds": 1800,
  "session_cache_size": 1000,
  "session_cleanup_interval_seconds": 60,
  "auto_save_domain_on_ok": true,
  "ambiguity_threshold": 0.7,
  "ambiguity_delta": 0.1,
  "domain_centroid_threshold": 0.3,
  "auto_save_domain_on_fallback": false,
  "use_relations": false,
  "relation_max_depth": 1,
  "relation_decay_factor": 0.5,
  "domain_centroids_min_concepts": 2,
  "use_metrics": false,
  "api_host": "127.0.0.1",
  "api_port": 8000,
  "domain_centroids_path": "",
  "api_key_enabled": false,
  "api_key": "",
  "rate_limit_rpm": 60,
  "environment": "development"
}