# AI-Terminator -- .gitignore
# Шаблон основан на github.com/github/gitignore/Python.gitignore

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# ============================================================
# Виртуальные окружения
# ============================================================
venv/
env/
.venv/
ENV/
env.bak/

# ============================================================
# IDE и редакторы
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Тестирование и покрытие
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ============================================================
# Логи
# ============================================================
logs/*.log
logs/*.log.*

# ============================================================
# ML-модели (большие бинарные файлы)
# ============================================================
models/*.bin
models/*.bin.gz
models/*.vec

# ============================================================
# Сгенерированные файлы данных
# ============================================================
data/knowledge_base.db
data/fallback_embeddings.npy
data/faiss.index
data/faiss.ids.json
data/domain_centroids.json
data/export_*.json
data/eval_results.json
data/synonyms.json

# ============================================================
# Конфиденциальные данные
# ============================================================
.env
*.env
secrets.json
credentials.json

# ============================================================
# GitHub Actions локальные файлы (НЕ добавлять в git)
# ============================================================
.github/workflows/secrets.env
.actrc

# pre-commit кэш
.pre-commit-cache/

# mkdocs
site/

# Локальные оврайды
configs/prod.local.json
